# API (optional — defaults work with docker compose)
PORT=3000
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=scalinglab

# Write pool → pgbouncer (primary)
WRITE_DB_HOST=localhost
WRITE_DB_PORT=5433

# Read pool → pgbouncer-read (replicas)
READ_DB_HOST=localhost
READ_DB_PORT=5436

# Redis cache
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TTL_SECONDS=30
# REDIS_ENABLED=false   # disable cache layer

# When running API inside docker compose, use:
# WRITE_DB_HOST=pgbouncer
# WRITE_DB_PORT=5432
# READ_DB_HOST=pgbouncer-read
# READ_DB_PORT=5432
